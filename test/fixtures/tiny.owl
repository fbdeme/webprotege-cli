<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xml:base="http://example.org/wpcli-smoke">
  <owl:Ontology rdf:about="http://example.org/wpcli-smoke"/>
  <owl:Class rdf:about="http://example.org/wpcli-smoke#Widget">
    <rdfs:label>Widget</rdfs:label>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/wpcli-smoke#Gadget">
    <rdfs:subClassOf rdf:resource="http://example.org/wpcli-smoke#Widget"/>
  </owl:Class>
</rdf:RDF>
